{
  "name": "claude-stats-vscode",
  "displayName": "Claude Stats",
  "description": "View Claude Code usage statistics in VS Code",
  "version": "0.1.0",
  "publisher": "claude-stats",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/deotio/claude-stats"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization", "Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-stats",
          "title": "Claude Stats",
          "icon": "media/icon-activity-bar.svg"
        }
      ]
    },
    "views": {
      "claude-stats": [
        {
          "id": "claude-stats.dashboardView",
          "name": "Dashboard"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "claude-stats.dashboardView",
        "contents": "View your Claude Code usage statistics.\n[Open Dashboard](command:claude-stats.openDashboard)"
      }
    ],
    "commands": [
      {
        "command": "claude-stats.openDashboard",
        "title": "Open Dashboard",
        "category": "Claude Stats"
      }
    ],
    "configuration": {
      "title": "Claude Stats",
      "properties": {
        "claude-stats.port": {
          "type": "number",
          "default": 9120,
          "description": "Port for the local dashboard server (used by the serve command)."
        },
        "claude-stats.autoRefreshSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 0,
          "description": "Auto-refresh interval in seconds for the dashboard panel. Set to 0 to disable."
        }
      }
    }
  }
}
